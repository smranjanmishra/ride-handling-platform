        <server>
            <id>releases</id>
            <username>${env.MAVEN_REPO_USERNAME}</username>
            <password>${env.MAVEN_REPO_PASSWORD}</password>
        </server>
    </servers>

    <profiles>
        <profile>
            <id>zeta</id>
            <repositories>
                <repository>
                    <id>releases</id>
                    <name>zeta-libs-release</name>
